{
  "framework": "nextjs",
  "regions": ["iad1"],
  "functions": {
    "app/api/report/generate/route.ts": {
      "maxDuration": 30
    },
    "app/api/ai-readiness/*/route.ts": {
      "maxDuration": 30
    },
    "app/api/reports/generate-pdf/route.ts": {
      "maxDuration": 30
    },
    "app/api/assessment/*/route.ts": {
      "maxDuration": 25
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/k12aiblueprint.html",
      "destination": "https://aireadiness.northpathstrategies.org/k12aiblueprint.html",
      "permanent": true,
      "has": [
        {
          "type": "header",
          "key": "host",
          "value": "(.+\\.)?vercel\\.app|app\\.northpathstrategies\\.org"
        }
      ]
    },
    {
      "source": "/k12aiblueprint",
      "destination": "https://aireadiness.northpathstrategies.org/k12aiblueprint.html",
      "permanent": true,
      "has": [
        {
          "type": "header",
          "key": "host",
          "value": "(.+\\.)?vercel\\.app|app\\.northpathstrategies\\.org"
        }
      ]
    },
    {
      "source": "/higheredaiblueprint.html",
      "destination": "https://aireadiness.northpathstrategies.org/higheredaiblueprint.html",
      "permanent": true,
      "has": [
        {
          "type": "header",
          "key": "host",
          "value": "(.+\\.)?vercel\\.app|app\\.northpathstrategies\\.org"
        }
      ]
    },
    {
      "source": "/higheredaiblueprint",
      "destination": "https://aireadiness.northpathstrategies.org/higheredaiblueprint.html",
      "permanent": true,
      "has": [
        {
          "type": "header",
          "key": "host",
          "value": "(.+\\.)?vercel\\.app|app\\.northpathstrategies\\.org"
        }
      ]
    }
  ]
}
