{
  "framework": "nextjs",
  "regions": ["iad1"],
  "functions": {
    "app/api/report/generate/route.ts": {
      "maxDuration": 30
    },
    "app/api/health/route.ts": {
      "maxDuration": 10
    },
    "app/api/pricing/unified/route.ts": {
      "maxDuration": 10
    },
    "app/api/ai-readiness/*/route.ts": {
      "maxDuration": 30
    },
    "app/api/reports/generate-pdf/route.ts": {
      "maxDuration": 30
    },
    "app/api/assessment/*/route.ts": {
      "maxDuration": 25
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/k12",
      "destination": "/k12-implementation",
      "permanent": false
    },
    {
      "source": "/highered",
      "destination": "/highered-implementation",
      "permanent": false
    },
    {
      "source": "/k12aiblueprint.html",
      "destination": "/k12aiblueprint.html",
      "permanent": true
    },
    {
      "source": "/k12aiblueprint",
      "destination": "/k12aiblueprint.html",
      "permanent": true
    },
    {
      "source": "/higheredaiblueprint.html",
      "destination": "/higheredaiblueprint.html",
      "permanent": true
    },
    {
      "source": "/higheredaiblueprint",
      "destination": "/higheredaiblueprint.html",
      "permanent": true
    }
  ]
}
