# AI Readiness App Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# ===== CORE APP CONFIGURATION =====
# For production, use your AI Blueprint custom domain
NEXT_PUBLIC_APP_URL="https://aireadiness.northpathstrategies.org"
NEXT_PUBLIC_BASE_URL="https://aireadiness.northpathstrategies.org"
NEXT_PUBLIC_DOMAIN="aireadiness.northpathstrategies.org"

# For local development
# NEXT_PUBLIC_APP_URL="http://localhost:3000"
# NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ===== OPENAI API =====
OPENAI_API_KEY="your-openai-api-key-here"
OPENAI_ORG_ID="your-openai-org-id-here"

# ===== STRIPE PAYMENT PROCESSING =====
# Get these from your Stripe Dashboard
STRIPE_SECRET_KEY="your-stripe-secret-key-here"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="your-stripe-publishable-key-here"
STRIPE_WEBHOOK_SECRET="your-webhook-secret-here"

# AI Blueprint Stripe Price IDs (replace with your actual price IDs)
STRIPE_PRICE_AI_BLUEPRINT_ESSENTIALS_MONTHLY="price_xxxxxxxxxxxxxxxxx"
STRIPE_PRICE_AI_BLUEPRINT_PROFESSIONAL_MONTHLY="price_xxxxxxxxxxxxxxxxx"
STRIPE_COUPON_AIREADY2025="your-coupon-code-here"

# ===== SUPABASE DATABASE =====
NEXT_PUBLIC_SUPABASE_URL="your-supabase-url-here"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key-here"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key-here"

# ===== EMAIL SERVICE (SendGrid) =====
SENDGRID_API_KEY="your-sendgrid-api-key-here"
SENDGRID_FROM_EMAIL="noreply@northpathstrategies.org"
SENDGRID_FROM_NAME="AI Blueprint Platform"

# ===== AUTHENTICATION (NextAuth) =====
NEXTAUTH_URL="https://aireadiness.northpathstrategies.org"
NEXTAUTH_SECRET="your-nextauth-secret-here"

# ===== ANALYTICS =====
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"
NEXT_PUBLIC_ENABLE_ANALYTICS_IN_DEV="false"

# ===== AI ANALYSIS & SCORING =====
AI_ANALYSIS_MODEL="gpt-4"
AI_TEMPERATURE="0.7"
AI_MAX_TOKENS="2000"
