# AI Readiness App - Production Environment Variables

# Domain Configuration
NEXT_PUBLIC_DOMAIN=ai-readiness.northpathstrategies.org
NEXT_PUBLIC_APP_URL=https://ai-readiness.northpathstrategies.org
NEXT_PUBLIC_BASE_URL=https://ai-readiness.northpathstrategies.org
NEXTAUTH_URL=https://ai-readiness.northpathstrategies.org

# OpenAI Configuration (CRITICAL for AI features)
OPENAI_API_KEY=your_production_openai_key
ENABLE_ADVANCED_AI=true
AI_CONTENT_GENERATION_TIMEOUT=15000
PDF_GENERATION_TIMEOUT=30000

# Database Configuration
DATABASE_URL=your_production_database_url
SUPABASE_URL=your_production_supabase_url
SUPABASE_ANON_KEY=your_production_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_production_supabase_service_key

# Authentication
NEXTAUTH_SECRET=your_secure_nextauth_secret

# Stripe Payment Processing (CRITICAL for subscriptions)
STRIPE_SECRET_KEY=your_production_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_production_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_production_stripe_webhook_secret

# Stripe Price IDs for AI Blueprint Subscriptions
STRIPE_PRICE_AI_BLUEPRINT_ESSENTIALS_MONTHLY=price_1Rsp7LGrA5DxvwDNHgskPPpl
STRIPE_PRICE_AI_BLUEPRINT_PROFESSIONAL_MONTHLY=price_1Rsp7MGrA5DxvwDNUNqx3Lsf

# SendGrid Email Configuration
SENDGRID_API_KEY=your_production_sendgrid_key
FROM_EMAIL=noreply@aireadiness.northpathstrategies.org

# Analytics & Monitoring
ENABLE_ANALYTICS=true
ENABLE_PERFORMANCE_MONITORING=true
VERCEL_ANALYTICS_ID=your_vercel_analytics_id

# AI Features Configuration
ENABLE_HISTORICAL_ANALYSIS=true
ENABLE_PEER_BENCHMARKING=true
ENABLE_ENHANCED_PDF=true
ENABLE_AI_IMAGE_GENERATION=false
