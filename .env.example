# AI Readiness App Environment Configuration
# Development Environment - DO NOT USE IN PRODUCTION

# Database Configuration (Development)
DATABASE_URL="sqlite://ai-readiness-dev.db"

# OpenAI Configuration (Development)
OPENAI_API_KEY="your-openai-api-key-here"
OPENAI_MODEL="gpt-4"

# Stripe Configuration (Development)
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key_here"
STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key_here"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret_here"

# App Configuration
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Security
JWT_SECRET="your-jwt-secret-here-change-in-production"

# Email Configuration (Optional)
SMTP_HOST="localhost"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# Analytics (Optional)
GOOGLE_ANALYTICS_ID=""
MIXPANEL_TOKEN=""

# AI Features Configuration (migrated)
NEXT_PUBLIC_AI_READINESS_SUPABASE_URL=https://your-ai-readiness-project.supabase.co
NEXT_PUBLIC_AI_READINESS_SUPABASE_ANON_KEY=your-ai-readiness-anon-key
